---
import type { Locale } from '../i18n/utils';
import { t, isRtl, getAlternateUrls, DEFAULT_LOCALE, localizePath } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../../src/styles/global.css';

interface Props {
  locale?: Locale;
  title: string;
  description: string;
  currentPath?: string;
  publishDate?: Date;
  author?: string;
  category?: string;
  featuredImage?: string;
}

const {
  locale = DEFAULT_LOCALE,
  title,
  description,
  currentPath = '/',
  publishDate,
  author,
  category,
  featuredImage,
} = Astro.props;

const dir = isRtl(locale) ? 'rtl' : 'ltr';
const canonicalURL = new URL(currentPath, Astro.site);
const alternateUrls = getAlternateUrls(currentPath);
const pathWithoutLocale = currentPath.replace(/^\/[a-z]{2}(\/|$)/, '$1') || '/';
const xDefaultURL = new URL(pathWithoutLocale, Astro.site);

const blogSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": canonicalURL.href,
  "datePublished": publishDate?.toISOString() ?? undefined,
  "dateModified": publishDate?.toISOString() ?? undefined,
  "author": author ? { "@type": "Person", "name": author } : undefined,
  "reviewer": {
    "@type": "Person",
    "name": "Dr. Sarah Mitchell",
    "jobTitle": "Mathematical Reviewer",
    "honorificPrefix": "Dr.",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Extrapolation Calculator",
    "url": "https://extrapolationcalculator.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://extrapolationcalculator.com/favicon.svg",
    },
  },
  "image": featuredImage ?? undefined,
};
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="AVoChEVeeZ7SyLvShE344lwOkUYBe4iILRRZL9WDNnw" />
    <meta name="msvalidate.01" content="D136AF6984B9A82D93051EC15C6D5386" />
    <script is:inline>
      (function(){try{var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}}catch(e){}})()
    </script>

    <title>{title.length > 30 ? title.slice(0, 27) + '…' : title} | ExtrapolationCalculator.com</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={featuredImage ?? 'https://extrapolationcalculator.com/og-default.svg'} />
    <meta property="og:site_name" content="Extrapolation Calculator" />
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {author && <meta property="article:author" content={author} />}

    <meta name="twitter:card" content={featuredImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={featuredImage ?? 'https://extrapolationcalculator.com/og-default.svg'} />

    {alternateUrls.map(({ locale: altLocale, url: altUrl }) => (
      <link rel="alternate" hreflang={altLocale} href={new URL(altUrl, Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultURL.href} />

    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

    {locale !== 'en' && (
      <script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async></script>
      <script is:inline>
        function googleTranslateElementInit() {
          new google.translate.TranslateElement({
            pageLanguage: 'en',
            includedLanguages: 'hi,es,ru,fr,de,it,pt,bn,ja,ko,ms,pl,id,ar,bg,tr,sv',
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
            autoDisplay: true
          }, 'google_translate_element');
        }
      </script>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-[#f8f8fc] dark:bg-[#0a0a0a] text-neutral-900 dark:text-neutral-100 transition-colors duration-300">
    {locale !== 'en' && (
      <div id="google_translate_element" class="fixed top-0 left-0 z-[60] opacity-0 pointer-events-none h-0 w-0 overflow-hidden"></div>
      <script is:inline>
        (function(){var locale=document.documentElement.lang;if(locale&&locale!=='en'){var interval=setInterval(function(){var sel=document.querySelector('.goog-te-combo');if(sel){sel.value=locale;sel.dispatchEvent(new Event('change'));clearInterval(interval)}},200);setTimeout(function(){clearInterval(interval)},8000)}})();
      </script>
    )}
    <Header locale={locale} currentPath={currentPath} />
    <main id="main-content" class="flex-1 px-4 sm:px-6 lg:px-8 overflow-hidden">
      <article class="max-w-3xl mx-auto py-16 md:py-24">
        <nav class="mb-6" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400">
            <li><a href={localizePath('/', locale)} class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors">Home</a></li>
            <li><svg class="h-3.5 w-3.5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
            <li><a href={localizePath('/blog/', locale)} class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors">Blog</a></li>
            <li><svg class="h-3.5 w-3.5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
            <li class="text-neutral-900 dark:text-neutral-100 font-medium truncate max-w-[200px]" aria-current="page">{title}</li>
          </ol>
        </nav>
        <header class="mb-10">
          {category && (
            <span class="inline-block bg-gold-500/10 text-gold-600 dark:text-gold-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 tracking-wide uppercase border border-gold-500/20">{category}</span>
          )}
          <h1 class="font-serif text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 leading-tight">{title}</h1>
          <div class="flex items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400">
            {author && (
              <span class="flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                {author}
              </span>
            )}
            {publishDate && (
              <time datetime={publishDate.toISOString()} class="flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {publishDate.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
          </div>
          <div class="flex items-center gap-2 mt-3 text-xs text-neutral-500 dark:text-neutral-500">
            <svg class="h-3.5 w-3.5 text-gold-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 10.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0-5.591 3.824-10.29 9-11.622 5.176 1.332 9 6.03 9 11.622 0 1.21-.174 2.38-.498 3.488z" /></svg>
            <span>Reviewed by <strong class="text-neutral-600 dark:text-neutral-400">Dr. Sarah Mitchell</strong>, Ph.D. Applied Mathematics</span>
          </div>
        </header>
        {featuredImage && (
          <img src={featuredImage} alt={title} class="w-full rounded-xl mb-10 shadow-lg" loading="lazy" />
        )}
        <div class="prose prose-neutral dark:prose-invert max-w-none dark:text-neutral-300 text-lg leading-relaxed">
          <slot />
        </div>

        <section class="mt-16 border-t border-neutral-200 dark:border-neutral-700 pt-12">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3">{t(locale, 'cta.tools.title')}</h2>
          <p class="text-neutral-600 dark:text-neutral-400 mb-8 text-lg">{t(locale, 'cta.tools.description')}</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a href={localizePath('/', locale)} class="group block calculator-card p-6 hover:border-gold-500/60 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
                <svg class="h-6 w-6 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">{t(locale, 'cta.tools.extrapolation')}</h3>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4 leading-relaxed">{t(locale, 'cta.tools.extrapolation.desc')}</p>
              <span class="text-sm font-semibold text-gold-600 dark:text-gold-400 group-hover:underline underline-offset-2">{t(locale, 'cta.tools.tryIt')} &rarr;</span>
            </a>
            <a href={localizePath('/interpolation/', locale)} class="group block calculator-card p-6 hover:border-gold-500/60 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-600/10 border border-blue-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
                <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">{t(locale, 'cta.tools.interpolation')}</h3>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4 leading-relaxed">{t(locale, 'cta.tools.interpolation.desc')}</p>
              <span class="text-sm font-semibold text-gold-600 dark:text-gold-400 group-hover:underline underline-offset-2">{t(locale, 'cta.tools.tryIt')} &rarr;</span>
            </a>
            <a href={localizePath('/regression/', locale)} class="group block calculator-card p-6 hover:border-gold-500/60 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500/20 to-emerald-600/10 border border-emerald-500/20 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
                <svg class="h-6 w-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
              </div>
              <h3 class="font-serif text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">{t(locale, 'cta.tools.regression')}</h3>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4 leading-relaxed">{t(locale, 'cta.tools.regression.desc')}</p>
              <span class="text-sm font-semibold text-gold-600 dark:text-gold-400 group-hover:underline underline-offset-2">{t(locale, 'cta.tools.tryIt')} &rarr;</span>
            </a>
          </div>
        </section>

        <section class="mt-12 border-t border-neutral-200 dark:border-neutral-700 pt-12">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">{t(locale, 'author.about')}</h2>
          <div class="flex flex-col sm:flex-row gap-5 items-start">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center flex-shrink-0">
              <svg class="h-8 w-8 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            </div>
            <div>
              <p class="font-serif text-lg font-semibold text-neutral-900 dark:text-neutral-100">{author}</p>
              <p class="text-neutral-600 dark:text-neutral-400 text-sm mt-2 leading-relaxed">{t(locale, 'author.bio')}</p>
            </div>
          </div>
        </section>
      </article>
    </main>
    <Footer locale={locale} />
  </body>
</html>
