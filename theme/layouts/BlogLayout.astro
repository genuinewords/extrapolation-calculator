---
import type { Locale } from '../i18n/utils';
import { t, isRtl, getAlternateUrls, DEFAULT_LOCALE } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../../src/styles/global.css';

interface Props {
  locale?: Locale;
  title: string;
  description: string;
  currentPath?: string;
  publishDate?: Date;
  author?: string;
  category?: string;
  featuredImage?: string;
}

const {
  locale = DEFAULT_LOCALE,
  title,
  description,
  currentPath = '/',
  publishDate,
  author,
  category,
  featuredImage,
} = Astro.props;

const dir = isRtl(locale) ? 'rtl' : 'ltr';
const canonicalURL = new URL(currentPath, Astro.site);
const alternateUrls = getAlternateUrls(currentPath);

const blogSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": canonicalURL.href,
  "datePublished": publishDate?.toISOString() ?? undefined,
  "dateModified": publishDate?.toISOString() ?? undefined,
  "author": author ? { "@type": "Person", "name": author } : undefined,
  "reviewer": {
    "@type": "Person",
    "name": "Dr. Sarah Mitchell",
    "jobTitle": "Mathematical Reviewer",
    "honorificPrefix": "Dr.",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Extrapolation Calculator",
    "url": "https://extrapolationcalculator.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://extrapolationcalculator.com/favicon.svg",
    },
  },
  "image": featuredImage ?? undefined,
};
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="AVoChEVeeZ7SyLvShE344lwOkUYBe4iILRRZL9WDNnw" />
    <meta name="msvalidate.01" content="D136AF6984B9A82D93051EC15C6D5386" />
    <script is:inline>
      (function(){try{var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}}catch(e){}})()
    </script>

    <title>{title} | {t(locale, 'site.title')}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    {featuredImage && <meta property="og:image" content={featuredImage} />}
    {publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
    {author && <meta property="article:author" content={author} />}

    <meta name="twitter:card" content={featuredImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {featuredImage && <meta name="twitter:image" content={featuredImage} />}

    {alternateUrls.map(({ locale: altLocale, url: altUrl }) => (
      <link rel="alternate" hreflang={altLocale} href={new URL(altUrl, Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={Astro.site?.href} />

    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-[#f8f8fc] dark:bg-[#0a0a0a] text-neutral-900 dark:text-neutral-100 transition-colors duration-300">
    <Header locale={locale} currentPath={currentPath} />
    <main id="main-content" class="flex-1 px-4 sm:px-6 lg:px-8 overflow-hidden">
      <article class="max-w-3xl mx-auto py-16 md:py-24">
        <header class="mb-10">
          {category && (
            <span class="inline-block bg-gold-500/10 text-gold-600 dark:text-gold-400 text-xs font-semibold px-4 py-1.5 rounded-full mb-4 tracking-wide uppercase border border-gold-500/20">{category}</span>
          )}
          <h1 class="font-serif text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 leading-tight">{title}</h1>
          <div class="flex items-center gap-4 text-sm text-neutral-500 dark:text-neutral-400">
            {author && (
              <span class="flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                {author}
              </span>
            )}
            {publishDate && (
              <time datetime={publishDate.toISOString()} class="flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {publishDate.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
          </div>
          <div class="flex items-center gap-2 mt-3 text-xs text-neutral-500 dark:text-neutral-500">
            <svg class="h-3.5 w-3.5 text-gold-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 10.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0-5.591 3.824-10.29 9-11.622 5.176 1.332 9 6.03 9 11.622 0 1.21-.174 2.38-.498 3.488z" /></svg>
            <span>Reviewed by <strong class="text-neutral-600 dark:text-neutral-400">Dr. Sarah Mitchell</strong>, Ph.D. Applied Mathematics</span>
          </div>
        </header>
        {featuredImage && (
          <img src={featuredImage} alt={title} class="w-full rounded-xl mb-10 shadow-lg" loading="lazy" />
        )}
        <div class="prose prose-neutral dark:prose-invert max-w-none dark:text-neutral-300 text-lg leading-relaxed">
          <slot />
        </div>
      </article>
    </main>
    <Footer locale={locale} />
  </body>
</html>
