---
import type { Locale } from '../i18n/utils';
import { t, isRtl, getAlternateUrls, DEFAULT_LOCALE } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
  currentPath?: string;
  ogImage?: string;
  schemaOrg?: object;
}

const {
  locale = DEFAULT_LOCALE,
  title,
  description,
  currentPath = '/',
  ogImage,
  schemaOrg,
} = Astro.props;

const dir = isRtl(locale) ? 'rtl' : 'ltr';
const siteTitle = title ?? t(locale, 'site.title');
const siteDescription = description ?? t(locale, 'site.description');
const canonicalURL = new URL(currentPath, Astro.site);
const alternateUrls = getAlternateUrls(currentPath);

const defaultSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": t(locale, 'site.title'),
  "applicationCategory": "MathApplication",
  "operatingSystem": "Web Browser",
  "description": siteDescription,
  "featureList": [
    "Linear Extrapolation",
    "Exponential Growth Calculation",
    "Polynomial Trend Analysis",
    "Statistical Confidence Intervals",
  ],
};

const schema = schemaOrg ?? defaultSchema;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Extrapolation Calculator",
  "url": "https://extrapolationcalculator.com",
  "logo": "https://extrapolationcalculator.com/favicon.svg",
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "support@extrapolationcalculator.com",
    "telephone": "+1-310-591-4962",
    "contactType": "customer support",
    "areaServed": "US",
    "availableLanguage": ["English", "Spanish", "French", "German", "Hindi", "Arabic"],
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "4403 Sumner Street",
    "addressLocality": "Riverside",
    "addressRegion": "CA",
    "addressCountry": "US",
  },
  "sameAs": [],
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Dr. Sarah Mitchell",
  "jobTitle": "Mathematical Reviewer",
  "honorificPrefix": "Dr.",
  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "Stanford University",
  },
  "knowsAbout": ["Applied Mathematics", "Statistical Modeling", "Numerical Analysis", "Regression Analysis", "Extrapolation Methods"],
  "description": "Ph.D. in Applied Mathematics from Stanford University with 15+ years of experience in statistical modeling and numerical analysis.",
};
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="AVoChEVeeZ7SyLvShE344lwOkUYBe4iILRRZL9WDNnw" />
    <meta name="msvalidate.01" content="D136AF6984B9A82D93051EC15C6D5386" />
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})();
    </script>

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonicalURL.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />

    {alternateUrls.map(({ locale: altLocale, url: altUrl }) => (
      <link rel="alternate" hreflang={altLocale} href={new URL(altUrl, Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={Astro.site?.href} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet" />

    {locale !== 'en' && (
      <script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async></script>
      <script is:inline>
        function googleTranslateElementInit() {
          new google.translate.TranslateElement({
            pageLanguage: 'en',
            includedLanguages: 'hi,es,ru,fr,de,it,pt,bn,ja,ko,ms,pl,id,ar,bg,tr,sv',
            layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
            autoDisplay: true
          }, 'google_translate_element');
        }
      </script>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-[#f8f8fc] dark:bg-[#0a0a0a] text-neutral-900 dark:text-neutral-100 transition-colors duration-300">
    {locale !== 'en' && (
      <div id="google_translate_element" class="fixed top-0 left-0 z-[60]"></div>
      <script is:inline>
        (function(){var locale=document.documentElement.lang;if(locale&&locale!=='en'){var interval=setInterval(function(){var sel=document.querySelector('.goog-te-combo');if(sel){sel.value=locale;sel.dispatchEvent(new Event('change'));clearInterval(interval)}},200);setTimeout(function(){clearInterval(interval)},8000)}})();
      </script>
    )}
    <Header locale={locale} currentPath={currentPath} />
    <main id="main-content" class="flex-1 px-4 sm:px-6 lg:px-8 overflow-hidden">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
