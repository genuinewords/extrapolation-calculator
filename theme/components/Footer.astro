---
import type { Locale } from '../i18n/utils';
import { t, localizePath, isRtl } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dir = isRtl(locale) ? 'rtl' : 'ltr';
const year = new Date().getFullYear();

const socialIcons = [
  { name: 'X', href: 'https://x.com/extrapolationcalculator', path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { name: 'LinkedIn', href: 'https://www.linkedin.com/company/extrapolationcalculator', path: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 110-4 2 2 0 010 4z' },
  { name: 'Facebook', href: 'https://www.facebook.com/extrapolationcalculator', path: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
];
---

<footer dir={dir} class="relative bg-neutral-900 text-neutral-300 mt-auto border-t border-gold-500/20 shadow-[0_-4px_30px_rgba(0,0,0,0.3)] dark:shadow-[0_-4px_30px_rgba(255,255,255,0.03)]">
  <!-- Gold accent line at top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/40 to-transparent" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand Column -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center">
            <span class="font-serif text-xl text-gold-500 leading-none">&#10022;</span>
          </div>
          <h3 class="text-white font-serif text-xl tracking-wide">{t(locale, 'site.title')}</h3>
        </div>
        <p class="text-sm text-neutral-400 leading-relaxed max-w-xs">{t(locale, 'site.description')}</p>
        <!-- Social Icons -->
        <div class="flex items-center gap-3 mt-6">
          {socialIcons.map((icon) => (
            <a href={icon.href} aria-label={icon.name} class="w-9 h-9 rounded-lg bg-neutral-800/80 border border-neutral-700/50 flex items-center justify-center text-neutral-400 hover:text-gold-400 hover:border-gold-500/30 hover:bg-gold-500/10 transition-all duration-300">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon.path} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Links Column -->
      <div>
        <h3 class="text-white font-serif font-semibold mb-5 text-lg tracking-wide">{t(locale, 'footer.links')}</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={localizePath('/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.home')}</a></li>
          <li><a href={localizePath('/interpolation/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.interpolation')}</a></li>
          <li><a href={localizePath('/regression/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.regression')}</a></li>
          <li><a href={localizePath('/about-us/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.about')}</a></li>
          <li><a href={localizePath('/contact-us/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.contact')}</a></li>
        </ul>
      </div>

      <!-- Legal Column -->
      <div>
        <h3 class="text-white font-serif font-semibold mb-5 text-lg tracking-wide">{t(locale, 'footer.legal')}</h3>
        <ul class="space-y-3 text-sm">
          <li><a href={localizePath('/terms/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.terms')}</a></li>
          <li><a href={localizePath('/privacy/', locale)} class="text-neutral-400 hover:text-gold-400 transition-colors duration-300 flex items-center gap-2.5 group"><span class="w-1.5 h-1.5 rounded-full bg-gold-500/40 group-hover:bg-gold-400 transition-colors" />{t(locale, 'nav.privacy')}</a></li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-white font-serif font-semibold mb-5 text-lg tracking-wide">{t(locale, 'footer.contact')}</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2.5 text-neutral-400">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.619a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            <a href="mailto:support@extrapolationcalculator.com" class="hover:text-gold-400 transition-colors duration-300">support@extrapolationcalculator.com</a>
          </li>
          <li class="flex items-start gap-2.5 text-neutral-400">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
            <a href="tel:310-591-4962" class="hover:text-gold-400 transition-colors duration-300">310-591-4962</a>
          </li>
          <li class="flex items-start gap-2.5 text-neutral-400">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-gold-500/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            <span>4403 Sumner Street, Riverside, CA</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-neutral-800/80 mt-12 pt-8 text-center">
      <div class="gold-divider-wide mb-6" />
      <p class="text-sm text-neutral-500 font-serif tracking-wide">&copy; {year} {t(locale, 'site.title')}. {t(locale, 'footer.rights')}</p>
    </div>
  </div>
</footer>
