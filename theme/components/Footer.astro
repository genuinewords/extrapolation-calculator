import type { Locale } from '../i18n/utils';
import { t, localizePath, isRtl } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dir = isRtl(locale) ? 'rtl' : 'ltr';
const year = new Date().getFullYear();

<footer dir={dir} class="bg-neutral-900 text-neutral-300 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-white font-semibold mb-4">{t(locale, 'site.title')}</h3>
        <p class="text-sm text-neutral-400">{t(locale, 'site.description')}</p>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={localizePath('/', locale)} class="hover:text-white transition-colors">{t(locale, 'nav.home')}</a></li>
          <li><a href={localizePath('/about-us/', locale)} class="hover:text-white transition-colors">{t(locale, 'nav.about')}</a></li>
          <li><a href={localizePath('/blog/', locale)} class="hover:text-white transition-colors">{t(locale, 'nav.blog')}</a></li>
          <li><a href={localizePath('/contact-us/', locale)} class="hover:text-white transition-colors">{t(locale, 'nav.contact')}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={localizePath('/terms/', locale)} class="hover:text-white transition-colors">{t(locale, 'nav.terms')}</a></li>
          <li><a href={localizePath('/privacy/', locale)} class="hover:text-white transition-colors">{t(locale, 'nav.privacy')}</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-neutral-800 mt-8 pt-8 text-center text-sm text-neutral-500">
      <p>&copy; {year} {t(locale, 'site.title')}. {t(locale, 'footer.rights')}</p>
    </div>
  </div>
</footer>
