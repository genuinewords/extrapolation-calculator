---
interface Props {
  references?: string[];
}

const {
  references = [
    'Montgomery, D.C., Peck, E.A., & Vining, G.G. (2021). Introduction to Linear Regression Analysis (6th ed.). Wiley.',
    'Burden, R.L., & Faires, J.D. (2010). Numerical Analysis (9th ed.). Brooks/Cole, Cengage Learning.',
    'Press, W.H., et al. (2007). Numerical Recipes: The Art of Scientific Computing (3rd ed.). Cambridge University Press.',
    'Weisstein, E.W. "Least Squares Fitting." From MathWorld — A Wolfram Web Resource.',
  ],
} = Astro.props;
---

<section class="py-8 md:py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="section-card p-6 md:p-8">
      <div class="flex items-center gap-2 mb-6">
        <svg class="h-5 w-5 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 tracking-tight">References</h2>
      </div>
      <ol class="space-y-3 list-decimal list-inside">
        {references.map((ref) => (
          <li class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed pl-2">{ref}</li>
        ))}
      </ol>
    </div>
  </div>
</section>
