---
import type { Locale } from '../i18n/utils';
import { t, localizePath } from '../i18n/utils';

interface FAQItem {
  question: string;
  answer: string;
  category: string;
  display: boolean;
}

interface Props {
  locale: Locale;
  items?: FAQItem[];
}

const { locale } = Astro.props;

const defaultFAQs: FAQItem[] = [
  { question: t(locale, 'faq.q1'), answer: t(locale, 'faq.a1'), category: 'general', display: true },
  { question: t(locale, 'faq.q2'), answer: t(locale, 'faq.a2'), category: 'calculator', display: true },
  { question: t(locale, 'faq.q3'), answer: t(locale, 'faq.a3'), category: 'calculator', display: true },
  { question: t(locale, 'faq.q4'), answer: t(locale, 'faq.a4'), category: 'technical', display: true },
  { question: t(locale, 'faq.q5'), answer: t(locale, 'faq.a5'), category: 'technical', display: true },
  { question: t(locale, 'faq.q6'), answer: t(locale, 'faq.a6'), category: 'general', display: true },
];

const faqs = Astro.props.items ?? defaultFAQs;
const visibleFAQs = faqs.filter((f) => f.display);
---

<section class="py-16 md:py-24 max-w-4xl mx-auto" aria-labelledby="faq-heading">
  <div class="text-center mb-10">
    <h2 id="faq-heading" class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 tracking-tight">{t(locale, 'faq.title')}</h2>
    <div class="gold-divider mt-4 mb-2" />
  </div>
  <div class="space-y-4">
    {visibleFAQs.map((faq, i) => (
      <div class="calculator-card overflow-hidden border-l-4 border-l-gold-500/40 hover:border-l-gold-500 transition-all duration-300">
        <button
          class="w-full flex items-center justify-between px-6 py-5 text-left text-neutral-900 dark:text-neutral-100 font-semibold text-base leading-relaxed hover:bg-white/40 dark:hover:bg-neutral-800/30 transition-colors duration-300"
          aria-expanded="false"
          aria-controls={`faq-answer-${i}`}
          id={`faq-question-${i}`}
          onclick={`this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true'); document.getElementById('faq-answer-${i}').classList.toggle('hidden'); this.querySelector('.faq-chevron').classList.toggle('rotate-180')`}
        >
          <span class="font-serif tracking-wide">{faq.question}</span>
          <svg class="faq-chevron h-5 w-5 text-gold-500/60 dark:text-gold-400/60 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id={`faq-answer-${i}`} class="hidden px-6 pb-5 text-neutral-600 dark:text-neutral-400 text-base leading-relaxed" role="region" aria-labelledby={`faq-question-${i}`}>
          {faq.answer}
        </div>
      </div>
    ))}
  </div>
</section>
