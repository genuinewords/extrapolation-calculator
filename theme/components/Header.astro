---
import type { Locale } from '../i18n/utils';
import { t, localizePath, isRtl } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const dir = isRtl(locale) ? 'rtl' : 'ltr';
const navLinks = [
  { href: localizePath('/', locale), label: t(locale, 'nav.home') },
  { href: localizePath('/interpolation/', locale), label: 'Interpolation' },
  { href: localizePath('/regression/', locale), label: 'Regression' },
  { href: localizePath('/about-us/', locale), label: t(locale, 'nav.about') },
  { href: localizePath('/contact-us/', locale), label: t(locale, 'nav.contact') },
];
---

<header dir={dir} class="bg-white/70 dark:bg-neutral-950/70 backdrop-blur-xl border-b border-neutral-200/40 dark:border-neutral-800/40 sticky top-0 z-50 transition-colors duration-300">
  <a href="#main-content" class="skip-link" style="position:absolute;top:-100px;left:0;z-index:50;padding:0.5rem 1rem;background:#b5890d;color:#fff;border-radius:0 0 0.5rem 0;transition:top 0.2s;" onFocus="this.style.top='0'" onBlur="this.style.top='-100px'">{locale === 'ar' ? 'تخطي إلى المحتوى' : 'Skip to content'}</a>
  <nav class="section-container" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Luxury Logo -->
      <a href={localizePath('/', locale)} class="flex items-center gap-3 text-lg font-bold text-neutral-900 dark:text-neutral-100 hover:text-gold-600 dark:hover:text-gold-400 transition-colors duration-300 group">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center group-hover:shadow-glow-gold transition-all duration-300">
          <span class="font-serif text-xl text-gold-600 dark:text-gold-400 leading-none">&#10022;</span>
        </div>
        <span class="font-serif tracking-wide">{t(locale, 'site.title')}</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-gold-600 dark:hover:text-gold-400 transition-colors duration-300 px-1 py-1 border-b-2 border-transparent hover:border-gold-500/60"
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
        <LanguageSwitcher locale={locale} currentPath={currentPath} />
        <!-- Premium Theme Toggle -->
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="p-2.5 rounded-xl text-neutral-600 dark:text-neutral-400 hover:bg-gold-500/10 dark:hover:bg-gold-500/10 transition-all duration-300 hover:scale-110 focus:ring-2 focus:ring-gold-500 focus:outline-none border border-transparent hover:border-gold-500/20"
        >
          <svg id="theme-icon-sun" class="h-5 w-5 hidden text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg id="theme-icon-moon" class="h-5 w-5 hidden text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      </div>

      <!-- Mobile Controls -->
      <div class="flex items-center gap-2 md:hidden">
        <button
          id="theme-toggle-mobile"
          type="button"
          aria-label="Toggle dark mode"
          class="p-2.5 rounded-xl text-neutral-600 dark:text-neutral-400 hover:bg-gold-500/10 transition-all duration-300 hover:scale-110 focus:ring-2 focus:ring-gold-500 focus:outline-none border border-transparent hover:border-gold-500/20"
        >
          <svg id="theme-icon-sun-m" class="h-5 w-5 hidden text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg id="theme-icon-moon-m" class="h-5 w-5 hidden text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
        <button
          id="mobile-menu-button"
          class="p-2.5 rounded-xl text-neutral-600 dark:text-neutral-400 hover:bg-gold-500/10 transition-all duration-200 focus:ring-2 focus:ring-gold-500 focus:outline-none border border-transparent hover:border-gold-500/20"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle menu"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" class="hidden" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-6 pt-2" role="navigation" aria-label="Mobile navigation">
      <div class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-3 rounded-xl text-sm font-medium text-neutral-600 dark:text-neutral-300 hover:bg-gold-500/5 dark:hover:bg-gold-500/10 hover:text-gold-600 dark:hover:text-gold-400 transition-all duration-300"
          >
            {link.label}
          </a>
        ))}
        <div class="px-4 py-3">
          <LanguageSwitcher locale={locale} currentPath={currentPath} />
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    document.querySelectorAll('#theme-icon-sun, #theme-icon-sun-m').forEach(el => {
      (el as HTMLElement).style.display = isDark ? 'block' : 'none';
    });
    document.querySelectorAll('#theme-icon-moon, #theme-icon-moon-m').forEach(el => {
      (el as HTMLElement).style.display = isDark ? 'none' : 'block';
    });
  }

  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');
    if (isDark) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateThemeIcons();
  }

  updateThemeIcons();

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
