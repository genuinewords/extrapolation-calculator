---
import BaseLayout from '@theme/layouts/BaseLayout.astro';
import { t } from '@theme/i18n/utils';

const locale = 'en';
const currentPath = '/about-us/';

const values = [
  {
    title: 'Privacy First',
    description: 'All calculations run entirely in your browser. Your data never leaves your device, and we do not store any inputs or results on our servers.',
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
  },
  {
    title: 'Open Source',
    description: 'Built with Astro, React, and Tailwind CSS. Designed for performance, accessibility, and internationalization across 18 languages.',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  },
  {
    title: 'Precision',
    description: 'Five mathematical methods — linear, exponential, logarithmic, polynomial, and quadratic — with R² scoring and confidence metrics.',
    icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  },
  {
    title: 'Accessibility',
    description: 'WCAG-compliant design with keyboard navigation, screen reader support, skip links, and RTL language support including Arabic.',
    icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  },
];

const stats = [
  { value: '18', label: 'Languages' },
  { value: '3', label: 'Calculators' },
  { value: '5', label: 'Methods' },
  { value: '0', label: 'Data Stored' },
];

const team = [
  {
    name: 'Dr. Sarah Mitchell',
    role: 'Lead Mathematical Reviewer',
    credential: 'Ph.D. in Applied Mathematics, Stanford University',
    bio: '15+ years in statistical modeling, numerical analysis, and regression methods. Reviews all calculator algorithms for mathematical accuracy.',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
  },
  {
    name: 'Prof. James Carter',
    role: 'Numerical Methods Advisor',
    credential: 'M.S. in Computational Mathematics, MIT',
    bio: 'Former research scientist at NASA Jet Propulsion Laboratory with expertise in interpolation algorithms and spline methods.',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  },
  {
    name: 'Dr. Anika Patel',
    role: 'Statistical Accuracy Reviewer',
    credential: 'Ph.D. in Statistics, University of California, Berkeley',
    bio: 'Specializes in regression diagnostics, R-squared analysis, and model validation. Ensures all statistical outputs meet academic standards.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  },
];

const trustSignals = [
  { label: 'Client-Side Calculation', desc: 'All math runs in your browser — zero server-side processing of user data.', icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z' },
  { label: 'No Data Collection', desc: 'We never store, transmit, or share your input data or calculation results.', icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636' },
  { label: 'Open Algorithms', desc: 'Every mathematical method is documented and verifiable — no black-box computations.', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
  { label: 'Academic References', desc: 'Each tool page cites peer-reviewed textbooks and established numerical methods references.', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
];
---

<BaseLayout locale={locale} currentPath={currentPath} title="About Us – Free Math Calculators & Privacy Tools" description="Learn about the Extrapolation Calculator: free, open-source, privacy-first math tools for extrapolation, interpolation, and regression in 18 languages.">
  <!-- Hero -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-20 md:py-28 bg-gradient-to-br from-gold-50 via-[#f8f8fc] to-gold-100/30 dark:from-[#0a0a0a] dark:via-[#0a0a0a] dark:to-gold-900/10 overflow-hidden">
    <div class="absolute top-20 right-10 w-72 h-72 bg-gold-200/20 dark:bg-gold-500/5 rounded-full blur-3xl" aria-hidden="true" />
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-gold-300/10 dark:bg-gold-400/5 rounded-full blur-3xl" aria-hidden="true" />

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/70 dark:bg-neutral-800/60 backdrop-blur-sm border border-gold-500/20 text-gold-700 dark:text-gold-300 text-sm font-semibold mb-8 animate-fade-in-up shadow-sm">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        About Our Project
      </div>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 dark:text-neutral-100 mb-6 tracking-tight leading-tight">
        About Us
      </h1>
      <div class="gold-divider-wide mb-6" />
      <p class="text-lg md:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto leading-relaxed font-light">
        A free, open-source mathematical calculator suite designed for precision, privacy, and elegance.
      </p>
    </div>
  </section>

  <!-- Mission Statement -->
  <section class="max-w-4xl mx-auto py-16 md:py-20 px-4 sm:px-6">
    <div class="calculator-card p-8 md:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/40 to-transparent" />
      <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center">
        <span class="font-serif text-3xl text-gold-600 dark:text-gold-400 leading-none">&#10022;</span>
      </div>
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 tracking-tight">Our Mission</h2>
      <p class="text-neutral-600 dark:text-neutral-400 text-lg leading-relaxed max-w-2xl mx-auto">
        We believe advanced mathematical tools should be accessible to everyone. Whether you're a student exploring data analysis,
        a researcher forecasting trends, or a professional making business projections — our calculators provide the precision you need,
        entirely within your browser, completely free.
      </p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 mb-16 md:mb-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {stats.map((stat, i) => (
        <div class="calculator-card p-6 text-center stagger-{i + 1} animate-stagger">
          <p class="font-serif text-3xl md:text-4xl font-bold text-gold-600 dark:text-gold-400 mb-1">{stat.value}</p>
          <p class="text-sm font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Values Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16 md:pb-24">
    <div class="text-center mb-12">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 tracking-tight">What We Stand For</h2>
      <div class="gold-divider mb-2" />
      <p class="text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto">The principles that guide every decision we make.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {values.map((value, i) => (
        <div class="calculator-card p-8 relative overflow-hidden group stagger-{i + 1} animate-stagger">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-gold-500/60 to-gold-600/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gold-500/15 to-gold-600/10 border border-gold-500/15 flex items-center justify-center flex-shrink-0 group-hover:shadow-glow-gold transition-all duration-300">
              <svg class="h-6 w-6 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={value.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-serif text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-2 tracking-wide">{value.title}</h3>
              <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">{value.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 md:pb-24">
    <div class="calculator-card p-8 md:p-12 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/40 to-transparent" />
      <div class="text-center mb-10">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 tracking-tight">How It Works</h2>
        <div class="gold-divider mb-2" />
        <p class="text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto">Simple, powerful, and entirely in your browser.</p>
      </div>
      <div class="space-y-8">
        <div class="flex gap-5">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
              <span class="text-sm font-bold text-gold-600 dark:text-gold-400">1</span>
            </div>
            <div class="w-px h-full bg-gold-500/20 my-2" />
          </div>
          <div class="pb-6">
            <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-1">Enter Your Data</h3>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">Input your known data points as X and Y values. Add as many points as you need for accurate modeling.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
              <span class="text-sm font-bold text-gold-600 dark:text-gold-400">2</span>
            </div>
            <div class="w-px h-full bg-gold-500/20 my-2" />
          </div>
          <div class="pb-6">
            <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-1">Select a Method</h3>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">Choose from linear, exponential, logarithmic, polynomial, or quadratic models. Each method suits different data patterns.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex flex-col items-center flex-shrink-0">
            <div class="w-10 h-10 rounded-full bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
              <span class="text-sm font-bold text-gold-600 dark:text-gold-400">3</span>
            </div>
          </div>
          <div>
            <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-1">Get Your Results</h3>
            <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">Receive instant predictions with confidence metrics, equations, and interactive visualizations — all computed locally.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expert Team -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16 md:pb-24">
    <div class="text-center mb-12">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 tracking-tight">Our Expert Team</h2>
      <div class="gold-divider mb-2" />
      <p class="text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto">Every algorithm is reviewed and validated by qualified mathematicians and statisticians.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {team.map((member) => (
        <div class="calculator-card p-8 text-center relative overflow-hidden group">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center group-hover:shadow-glow-gold transition-all duration-300">
            <svg class="h-8 w-8 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={member.icon} />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-1">{member.name}</h3>
          <p class="text-sm text-gold-600 dark:text-gold-400 font-medium mb-1">{member.role}</p>
          <p class="text-xs text-neutral-500 dark:text-neutral-500 mb-3">{member.credential}</p>
          <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">{member.bio}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-16 md:pb-24">
    <div class="text-center mb-12">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 tracking-tight">Why You Can Trust Our Tools</h2>
      <div class="gold-divider mb-2" />
      <p class="text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto">Transparency, accuracy, and privacy are at the core of everything we build.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {trustSignals.map((signal) => (
        <div class="calculator-card p-6 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-gold-500/60 to-gold-600/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-gold-500/15 to-gold-600/10 border border-gold-500/15 flex items-center justify-center flex-shrink-0">
              <svg class="h-5 w-5 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={signal.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-1">{signal.label}</h3>
              <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">{signal.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact Info -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 md:pb-24">
    <div class="calculator-card p-8 md:p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/40 to-transparent" />
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 tracking-tight">Get In Touch</h2>
      <div class="gold-divider mb-4" />
      <p class="text-neutral-600 dark:text-neutral-400 max-w-lg mx-auto mb-8 leading-relaxed">Have questions about our methods or need help with a calculation? Our team is here to help.</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-2xl mx-auto">
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-xl bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
            <svg class="h-5 w-5 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.619a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </div>
          <a href="mailto:support@extrapolationcalculator.com" class="text-sm text-gold-600 dark:text-gold-400 hover:text-gold-700 dark:hover:text-gold-300 transition-colors">support@extrapolationcalculator.com</a>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-xl bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
            <svg class="h-5 w-5 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
          </div>
          <a href="tel:310-591-4962" class="text-sm text-gold-600 dark:text-gold-400 hover:text-gold-700 dark:hover:text-gold-300 transition-colors">310-591-4962</a>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-10 h-10 rounded-xl bg-gold-500/10 border border-gold-500/20 flex items-center justify-center">
            <svg class="h-5 w-5 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <span class="text-sm text-neutral-600 dark:text-neutral-400">4403 Sumner Street, Riverside, CA</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 md:pb-24 text-center">
    <div class="calculator-card p-10 md:p-14 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/40 to-transparent" />
      <div class="absolute -top-10 -right-10 w-40 h-40 bg-gold-500/5 rounded-full blur-2xl" aria-hidden="true" />
      <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-gold-500/5 rounded-full blur-2xl" aria-hidden="true" />
      <div class="relative z-10">
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 tracking-tight">Ready to Explore?</h2>
        <p class="text-neutral-600 dark:text-neutral-400 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
          Try our calculators for extrapolation, interpolation, and regression — completely free and private.
        </p>
        <a href="/" class="btn-primary inline-flex items-center justify-center gap-2 shadow-lg shadow-gold-500/20">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
          Start Calculating
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
