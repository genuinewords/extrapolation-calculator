---
import BaseLayout from '@theme/layouts/BaseLayout.astro';

const locale = 'en';
---

<BaseLayout locale={locale} currentPath="/404" title="Page Not Found – Extrapolation Calculator" description="The page you are looking for does not exist. Return to the Extrapolation Calculator homepage to use our free math tools.">
  <div class="max-w-2xl mx-auto py-24 text-center">
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4">Page Not Found</h1>
    <p class="text-8xl font-bold text-gold-500/20 dark:text-gold-400/15 mb-4">404</p>
    <p class="text-neutral-600 dark:text-neutral-400 mb-8 leading-relaxed">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="group inline-flex items-center justify-center gap-2.5 px-8 py-3.5 rounded-2xl font-semibold text-white transition-all duration-300 bg-gradient-to-r from-gold-700 via-gold-600 to-gold-500 shadow-lg shadow-gold-600/20 hover:shadow-glow-gold hover:scale-[1.03] active:scale-[0.98] focus:ring-2 focus:ring-gold-400 focus:ring-offset-2 focus:outline-none relative overflow-hidden">
      <svg class="h-5 w-5 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
      <span class="relative z-10">Go Home</span>
    </a>
  </div>
</BaseLayout>
