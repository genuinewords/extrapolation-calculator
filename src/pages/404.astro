---
import BaseLayout from '@theme/layouts/BaseLayout.astro';

const locale = 'en';
---

<BaseLayout locale={locale} currentPath="/404" title="Page Not Found" description="The page you are looking for does not exist.">
  <div class="max-w-2xl mx-auto py-24 text-center">
    <h1 class="text-6xl font-bold text-neutral-200 dark:text-neutral-700 mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-100 mb-4">Page Not Found</h2>
    <p class="text-neutral-600 dark:text-neutral-400 mb-8">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
      Go Home
    </a>
  </div>
</BaseLayout>
