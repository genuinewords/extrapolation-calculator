                <th class="text-left px-6 py-4 font-serif font-semibold text-neutral-900 dark:text-neutral-100 border-b border-neutral-200/60 dark:border-neutral-700/60">Interpolation</th>
                <th class="text-left px-6 py-4 font-serif font-semibold text-neutral-900 dark:text-neutral-100 border-b border-neutral-200/60 dark:border-neutral-700/60">Extrapolation</th>
              </tr>
            </thead>
            <tbody class="text-neutral-600 dark:text-neutral-400">
              <tr class="border-b border-neutral-100 dark:border-neutral-800/60">
