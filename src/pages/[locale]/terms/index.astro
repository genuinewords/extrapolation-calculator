---
import BaseLayout from '../../../../theme/layouts/BaseLayout.astro';
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath } from '../../../../theme/i18n/utils';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/terms/', locale);
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'nav.terms')} description="Terms of service.">
  <div class="max-w-4xl mx-auto py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">{t(locale, 'nav.terms')}</h1>
    <div class="prose prose-neutral dark:prose-invert max-w-none dark:text-neutral-300">
      <p>{t(locale, 'site.description')}</p>
      <p>{locale === 'en' ? 'By using this website, you agree to these terms. All calculations are performed client-side and we do not store your data.' : t(locale, 'site.description')}</p>
    </div>
  </div>
</BaseLayout>
