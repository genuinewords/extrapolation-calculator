---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath, isRtl } from '../../../theme/i18n/utils';
import BaseLayout from '../../../theme/layouts/BaseLayout.astro';
import FAQ from '../../../theme/components/FAQ.astro';
import ExtrapolationCalculator from '../../components/ExtrapolationCalculator';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/', locale);
const dir = isRtl(locale) ? 'rtl' : 'ltr';
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'site.title')} description={t(locale, 'site.description')}>
  <section class="bg-gradient-to-br from-primary/5 via-primary/3 to-white dark:from-primary/10 dark:via-primary/5 dark:to-neutral-950 py-20 md:py-32" dir={dir}>
    <div class="section-container text-center">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 dark:text-neutral-100 mb-6 leading-tight">
          {t(locale, 'hero.title')}
        </h1>
        <p class="text-lg md:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          {t(locale, 'hero.subtitle')}
        </p>
        <a href="#calculator" class="btn-primary shadow-lg hover:shadow-xl">
          {t(locale, 'hero.cta')}
        </a>
      </div>
    </div>
  </section>

  <section id="calculator" class="py-16 md:py-20">
    <div class="section-container">
      <ExtrapolationCalculator client:load locale={locale} />
    </div>
  </section>

  <FAQ locale={locale} />
</BaseLayout>
