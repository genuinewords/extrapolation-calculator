---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath, isRtl } from '@theme/i18n/utils';
import BaseLayout from '@theme/layouts/BaseLayout.astro';
import InterpolationCalculator from '../../../components/InterpolationCalculator';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/interpolation/', locale);
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'interpolation.title')} description={t(locale, 'interpolation.description')} schemaOrg={{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": t(locale, 'interpolation.title'),
  "applicationCategory": "MathApplication",
  "operatingSystem": "Web Browser",
  "description": t(locale, 'interpolation.description'),
  "featureList": ["Linear Interpolation", "Lagrange Polynomial", "Natural Cubic Spline"],
}}>
  <div class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-10">
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 dark:text-neutral-100 mb-4 leading-tight tracking-tight">{t(locale, 'interpolation.title').split(' – ')[0]}</h1>
        <div class="gold-divider-wide mb-6" />
        <p class="text-neutral-600 dark:text-neutral-400 text-lg leading-relaxed max-w-2xl mx-auto">{t(locale, 'interpolation.description')}</p>
      </div>
      <InterpolationCalculator client:idle locale={locale} />
    </div>
  </div>
</BaseLayout>
