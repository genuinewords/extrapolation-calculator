---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath } from '@theme/i18n/utils';
import BaseLayout from '@theme/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/about-us/', locale);
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'about.title')} description={t(locale, 'about.description')}>
  <div class="max-w-4xl mx-auto py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">{t(locale, 'about.title')}</h1>
    <div class="prose prose-neutral dark:prose-invert max-w-none dark:text-neutral-300">
      <p>{t(locale, 'site.description')}</p>
      <p>{locale === 'en' ? 'All calculations run entirely in your browser. Your data never leaves your device.' : t(locale, 'site.description')}</p>
    </div>
  </div>
</BaseLayout>
