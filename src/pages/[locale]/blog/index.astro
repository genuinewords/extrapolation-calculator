---
import BaseLayout from '../../../../theme/layouts/BaseLayout.astro';
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath } from '../../../../theme/i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/blog/', locale);
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'blog.title')} description={t(locale, 'site.description')}>
  <div class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-8">{t(locale, 'blog.title')}</h1>
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sortedPosts.map((post) => (
          <article class="calculator-card p-6 hover:shadow-md transition-shadow dark:bg-neutral-900 dark:border-neutral-700">
            {post.data.category && (
              <span class="inline-block bg-primary/10 text-primary text-xs font-medium px-3 py-1 rounded-full mb-3">{post.data.category}</span>
            )}
            <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-2">
              <a href={`/${locale}/blog/${post.id}/`} class="hover:text-primary transition-colors">{post.data.title}</a>
            </h2>
            <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-3">{post.data.description}</p>
            <div class="flex items-center justify-between text-xs text-neutral-500 dark:text-neutral-500">
              <span>{post.data.author}</span>
              <time datetime={post.data.publishDate.toISOString()}>
                {post.data.publishDate.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-neutral-500 dark:text-neutral-400">{t(locale, 'site.description')}</p>
    )}
  </div>
</BaseLayout>
