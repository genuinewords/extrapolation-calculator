---
import BlogLayout from '@theme/layouts/BlogLayout.astro';
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t } from '@theme/i18n/utils';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const basePosts = allPosts.filter(
    p => !SUPPORTED_LOCALES.some(l => l !== DEFAULT_LOCALE && p.id.startsWith(`${l}-`))
  );
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .flatMap((locale) =>
      basePosts.map((post) => {
        const slug = post.id.replace(/\.mdx$/, '');
        const localizedId = `${locale}-${slug}`;
        const localizedPost = allPosts.find(p => p.id === localizedId);
        return {
          params: { locale, slug },
          props: { locale, post: localizedPost ?? post },
        };
      })
    );
}

const { locale, post } = Astro.props;
const slug = post.id.replace(/\.mdx$/, '');
const { Content } = await post.render();
---

<BlogLayout
  locale={locale}
  title={post.data.title}
  description={post.data.description}
  currentPath={`/${locale}/blog/${slug}/`}
  publishDate={post.data.publishDate}
  author={post.data.author}
  category={post.data.category}
  featuredImage={post.data.featuredImage}
>
  <Content />
</BlogLayout>
