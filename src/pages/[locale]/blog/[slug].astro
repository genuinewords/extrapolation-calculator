---
import BlogLayout from '@theme/layouts/BlogLayout.astro';
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t } from '@theme/i18n/utils';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .flatMap((locale) =>
      posts.map((post) => ({
        params: { locale, slug: post.id.replace(/\.mdx$/, '') },
        props: { locale, post },
      }))
    );
}

const { locale, post } = Astro.props;
const slug = post.id.replace(/\.mdx$/, '');

// Load locale-specific content if available (e.g., hi- prefix for Hindi)
const allPosts = await getCollection('blog');
const localizedId = `${locale}-${slug}.mdx`;
const localizedPost = allPosts.find(p => p.id === localizedId);
const contentPost = localizedPost ?? post;
const { Content } = await contentPost.render();
---

<BlogLayout
  locale={locale}
  title={contentPost.data.title}
  description={contentPost.data.description}
  currentPath={`/${locale}/blog/${slug}/`}
  publishDate={contentPost.data.publishDate}
  author={contentPost.data.author}
  category={contentPost.data.category}
  featuredImage={contentPost.data.featuredImage}
>
  <Content />
</BlogLayout>
