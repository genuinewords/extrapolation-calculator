---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath } from '../../../../theme/i18n/utils';
import BaseLayout from '../../../../theme/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/contact-us/', locale);
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'contact.title')} description="Contact the Extrapolation Calculator team.">
  <div class="max-w-2xl mx-auto px-4 py-16">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-6">{t(locale, 'contact.title')}</h1>
    <form id="contact-form" class="space-y-6" action="https://api.web3forms.com/submit" method="POST" novalidate>
      <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_CONTACT_FORM_KEY} />
      <div>
        <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">{t(locale, 'contact.name')}</label>
        <input type="text" id="name" name="name" required class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary" aria-required="true" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">{t(locale, 'contact.email')}</label>
        <input type="email" id="email" name="email" required class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary" aria-required="true" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">{t(locale, 'contact.message')}</label>
        <textarea id="message" name="message" rows="5" required class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary resize-y" aria-required="true"></textarea>
      </div>
      <div id="form-status" role="status" aria-live="polite" class="hidden"></div>
      <button type="submit" class="w-full bg-primary text-white font-medium py-3 rounded-lg hover:bg-primary/90 transition-colors">
        {t(locale, 'contact.send')}
      </button>
    </form>
  </div>
</BaseLayout>
