---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath } from '../../../../theme/i18n/utils';
import BaseLayout from '../../../../theme/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/contact-us/', locale);
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'contact.title')} description="Contact the Extrapolation Calculator team.">
  <div class="max-w-2xl mx-auto py-16 md:py-24">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">{t(locale, 'contact.title')}</h1>
    <form id="contact-form" class="space-y-6" action="https://api.web3forms.com/submit" method="POST" novalidate>
      <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_CONTACT_FORM_KEY} />
      <div>
        <label for="name" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.name')}</label>
        <input type="text" id="name" name="name" required class="w-full border border-neutral-200 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-100 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary" aria-required="true" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.email')}</label>
        <input type="email" id="email" name="email" required class="w-full border border-neutral-200 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-100 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary" aria-required="true" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.message')}</label>
        <textarea id="message" name="message" rows="5" required class="w-full border border-neutral-200 dark:border-neutral-600 dark:bg-neutral-800 dark:text-neutral-100 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary resize-y" aria-required="true"></textarea>
      </div>
      <div id="form-status" role="status" aria-live="polite" class="hidden"></div>
      <button type="submit" class="w-full bg-primary text-white font-medium py-3 rounded-lg hover:bg-primary/90 transition-colors">
        {t(locale, 'contact.send')}
      </button>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = formData.get('name')?.toString().trim();
    const email = formData.get('email')?.toString().trim();
    const message = formData.get('message')?.toString().trim();

    if (!name || !email || !message) {
      status.textContent = 'Please fill in all fields.';
      status.className = 'p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-700 dark:text-red-300';
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      status.textContent = 'Please enter a valid email address.';
      status.className = 'p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-700 dark:text-red-300';
      return;
    }

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });
      if (response.ok) {
        status.textContent = 'Message sent successfully!';
        status.className = 'p-3 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-lg text-sm text-green-700 dark:text-green-300';
        form.reset();
      } else {
        status.textContent = 'Failed to send message. Please try again.';
        status.className = 'p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-700 dark:text-red-300';
      }
    } catch {
      status.textContent = 'Network error. Please try again later.';
      status.className = 'p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg text-sm text-red-700 dark:text-red-300';
    }
  });
</script>
