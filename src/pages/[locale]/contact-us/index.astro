---
import BaseLayout from '@theme/layouts/BaseLayout.astro';
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, t, localizePath } from '@theme/i18n/utils';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== DEFAULT_LOCALE)
    .map((locale) => ({
      params: { locale },
      props: { locale },
    }));
}

const { locale } = Astro.props;
const currentPath = localizePath('/contact-us/', locale);

const contactMethods = [
  {
    label: 'Email',
    value: 'support@extrapolationcalculator.com',
    href: 'mailto:support@extrapolationcalculator.com',
    icon: 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.619a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
  },
  {
    label: 'Phone',
    value: '310-591-4962',
    href: 'tel:310-591-4962',
    icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
  },
  {
    label: 'Address',
    value: '4403 Sumner Street, Riverside, CA',
    href: null,
    icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  },
];
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'contact.title')} description={t(locale, 'contact.description')}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 md:pt-24 pb-16 md:pb-24">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 dark:text-neutral-100 mb-6">{t(locale, 'contact.title')}</h1>
    <p class="text-neutral-600 dark:text-neutral-400 mb-12 max-w-2xl">{t(locale, 'contact.description')}</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {contactMethods.map((method) => (
        <div class="calculator-card p-8 text-center">
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center">
            <svg class="h-8 w-8 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={method.icon} />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-2">{method.label}</h3>
          {method.href ? (
            <a href={method.href} class="text-gold-600 dark:text-gold-400 hover:text-gold-700 dark:hover:text-gold-300 transition-colors text-sm">{method.value}</a>
          ) : (
            <span class="text-neutral-600 dark:text-neutral-400 text-sm">{method.value}</span>
          )}
        </div>
      ))}
    </div>

    <div class="calculator-card p-8 md:p-12 max-w-2xl mx-auto">
      <h2 class="font-serif text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-6 text-center">{t(locale, 'contact.title')}</h2>
      <form id="contact-form" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.name')}</label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.email')}</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.message')}</label>
          <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors resize-none" />
        </div>
        <div id="form-success" class="hidden text-green-600 dark:text-green-400 text-sm text-center">{t(locale, 'contact.success')}</div>
        <button type="submit" class="w-full btn-primary py-3 text-center shadow-lg shadow-gold-500/20">
          {t(locale, 'contact.send')}
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (successMsg) {
      successMsg.classList.remove('hidden');
    }
    form.reset();
  });
</script>
