---
import BaseLayout from '@theme/layouts/BaseLayout.astro';
import { t } from '@theme/i18n/utils';

const locale = 'en';
const currentPath = '/contact-us/';

const contactMethods = [
  {
    label: 'Email',
    value: 'support@extrapolationcalculator.com',
    href: 'mailto:support@extrapolationcalculator.com',
    icon: 'M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.619a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75',
  },
  {
    label: 'Phone',
    value: '310-591-4962',
    href: 'tel:310-591-4962',
    icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
  },
  {
    label: 'Address',
    value: '4403 Sumner Street, Riverside, CA',
    href: null,
    icon: 'M15 10.5a3 3 0 11-6 0 3 3 0 016 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
  },
];
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'contact.title')} description={t(locale, 'contact.description')}>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-8" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400">
      <li><a href="/" class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors">Home</a></li>
      <li><svg class="h-3.5 w-3.5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></li>
      <li class="text-neutral-900 dark:text-neutral-100 font-medium" aria-current="page">Contact Us</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-20 md:py-28 bg-gradient-to-br from-gold-50 via-[#f8f8fc] to-gold-100/30 dark:from-[#0a0a0a] dark:via-[#0a0a0a] dark:to-gold-900/10 overflow-hidden">
    <div class="absolute top-20 right-10 w-72 h-72 bg-gold-200/20 dark:bg-gold-500/5 rounded-full blur-3xl" aria-hidden="true" />
    <div class="absolute bottom-10 left-10 w-96 h-96 bg-gold-300/10 dark:bg-gold-400/5 rounded-full blur-3xl" aria-hidden="true" />
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/70 dark:bg-neutral-800/60 backdrop-blur-sm border border-gold-500/20 text-gold-700 dark:text-gold-300 text-sm font-semibold mb-8 animate-fade-in-up shadow-sm">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
        Get in Touch
      </div>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-neutral-900 dark:text-neutral-100 mb-6 tracking-tight leading-tight">
        Contact Us
      </h1>
      <div class="gold-divider-wide mb-6" />
      <p class="text-lg md:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto leading-relaxed font-light">
        {t(locale, 'contact.description')}
      </p>
    </div>
  </section>

  <!-- Contact Methods -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {contactMethods.map((method) => (
        <div class="calculator-card p-8 text-center relative overflow-hidden group">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          <div class="w-16 h-16 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-gold-500/20 to-gold-600/10 border border-gold-500/20 flex items-center justify-center group-hover:shadow-glow-gold transition-all duration-300">
            <svg class="h-8 w-8 text-gold-600 dark:text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={method.icon} />
            </svg>
          </div>
          <h3 class="font-serif text-lg font-bold text-neutral-900 dark:text-neutral-100 mb-2">{method.label}</h3>
          {method.href ? (
            <a href={method.href} class="text-gold-600 dark:text-gold-400 hover:text-gold-700 dark:hover:text-gold-300 transition-colors text-sm">{method.value}</a>
          ) : (
            <span class="text-neutral-600 dark:text-neutral-400 text-sm">{method.value}</span>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- Contact Form -->
  <section class="max-w-2xl mx-auto px-4 sm:px-6 pb-16 md:pb-24">
    <div class="calculator-card p-8 md:p-12 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold-500/40 to-transparent" />
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 tracking-tight text-center">Send Us a Message</h2>
      <div class="gold-divider mb-8" />
      <form id="contact-form" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.name')}</label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.email')}</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">{t(locale, 'contact.message')}</label>
          <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-900 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors resize-none" />
        </div>
        <div id="form-success" class="hidden text-green-600 dark:text-green-400 text-sm text-center">{t(locale, 'contact.success')}</div>
        <button type="submit" class="w-full btn-primary py-3 text-center shadow-lg shadow-gold-500/20">
          {t(locale, 'contact.send')}
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (successMsg) {
      successMsg.classList.remove('hidden');
    }
    form.reset();
  });
</script>
