---
import BaseLayout from '../../../theme/layouts/BaseLayout.astro';
import { t } from '../../../theme/i18n/utils';

const locale = 'en';
const currentPath = '/contact-us/';
---

<BaseLayout locale={locale} currentPath={currentPath} title={t(locale, 'contact.title')} description="Get in touch with the Extrapolation Calculator team.">
  <div class="max-w-2xl mx-auto px-4 py-16">
    <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-6">Contact Us</h1>
    <p class="text-neutral-600 mb-8">Have questions, feedback, or suggestions? We'd love to hear from you.</p>

    <form id="contact-form" class="space-y-6" action="https://api.web3forms.com/submit" method="POST" novalidate>
      <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_CONTACT_FORM_KEY} />
      <input type="hidden" name="subject" value="Contact Form Submission - Extrapolation Calculator" />
      <input type="hidden" name="from_name" value="Extrapolation Calculator" />

      <div>
        <label for="name" class="block text-sm font-medium text-neutral-700 mb-2">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          autocomplete="name"
          class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary"
          aria-required="true"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-neutral-700 mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary"
          aria-required="true"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-neutral-700 mb-2">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary focus:border-primary resize-y"
          aria-required="true"
        ></textarea>
      </div>

      <div id="form-status" role="status" aria-live="polite" class="hidden"></div>

      <button
        type="submit"
        class="w-full bg-primary text-white font-medium py-3 rounded-lg hover:bg-primary/90 transition-colors focus:ring-2 focus:ring-primary focus:ring-offset-2"
      >
        Send Message
      </button>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = formData.get('name')?.toString().trim();
    const email = formData.get('email')?.toString().trim();
    const message = formData.get('message')?.toString().trim();

    if (!name || !email || !message) {
      status.textContent = 'Please fill in all fields.';
      status.className = 'p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700';
      return;
    }

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      status.textContent = 'Please enter a valid email address.';
      status.className = 'p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700';
      return;
    }

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });
      if (response.ok) {
        status.textContent = 'Message sent successfully!';
        status.className = 'p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700';
        form.reset();
      } else {
        status.textContent = 'Failed to send message. Please try again.';
        status.className = 'p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700';
      }
    } catch {
      status.textContent = 'Network error. Please try again later.';
      status.className = 'p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700';
    }
  });
</script>
